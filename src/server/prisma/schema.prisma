generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String     @id @default(uuid())
  username        String     @unique
  password_hash   String
  is_admin        Boolean    @default(false)
  active_model_id String?
  created_at      DateTime   @default(now())
  AiConfigs     AiConfig[]
  Articles      Article[]
  Templates     Template[]
}

model AiConfig {
  id            String   @id @default(uuid())
  user_id       String
  provider_name String
  api_key       String
  base_url      String
  model_name    String
  user          User     @relation(fields: [user_id], references: [id])
}

model Article {
  id         String   @id @default(uuid())
  user_id    String
  topic      String
  outline    String?  // JSON string
  content    String?
  status     String   @default("DRAFT") // DRAFT, OUTLINE_DONE, COMPLETED
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id])
}

model Template {
  id         String   @id @default(uuid())
  user_id    String
  name       String
  style      String?
  framework  String?  // JSON string
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])
}

model SystemAiModel {
  id         String   @id @default(uuid())
  name       String
  model      String
  base_url   String
  api_key    String
  created_at DateTime @default(now())
}
